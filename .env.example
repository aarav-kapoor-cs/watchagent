# WatchAgent configuration.
# Open-Meteo needs no API key, so there are no secrets here — these are all
# tunable runtime settings. Copy to .env before running.

# Where the SQLite database file is written (inside the container).
DATABASE_PATH=/data/watchagent.db

# How often (seconds) the poller fetches each city. The API updates hourly,
# so polling more often is fine — duplicates are dropped by timestamp.
POLL_INTERVAL_SECONDS=300

# Network timeout for a single weather fetch (seconds).
HTTP_TIMEOUT_SECONDS=10

# How many recent readings the detector uses to build context.
DETECTION_WINDOW=6
